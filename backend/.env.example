# Madison Command Center — backend (BFF) configuration.
# Copy to `.env`. Each block is independent: fill only the sources you're wiring.
# The server is live-only: a route serves real data once that source is connected via
# OAuth, otherwise it returns 401 (Microsoft) / 503 (QuickBooks). There is no sample mode.

PORT=8787
# Allow the Vite dev server (and the published preview) to call this backend.
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ── Microsoft Graph (Outlook mail + calendar, To Do, Excel) — delegated, read-only ──
# Which Microsoft app/tenant this points at: sandbox (dev tenant) or production. Drives
# the source-status badge.
MS_ENV=sandbox
# Register a single-tenant Azure AD app; delegated scopes:
#   Mail.Read Calendars.Read Tasks.Read Files.Read offline_access
# Run the OAuth code flow ONCE as the owner, then paste the refresh token here.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=
# The owner's UPN/email (the mailbox we read). Used for /users/{id} if not /me.
MS_USER=

# Awaiting-response engine tuning (per the customer's backend spec)
AWAITING_THRESHOLD_HOURS=48
AWAITING_LOOKBACK_DAYS=14

# Weekly spreadsheet (Excel via Graph). The file in OneDrive/SharePoint + a metric map.
# SPREADSHEET_DRIVE_PATH e.g. /Reports/weekly.xlsx  (resolved under the owner's drive)
SPREADSHEET_DRIVE_PATH=
# JSON map of metric key -> named range, e.g. {"new_patients":"NewPatients", ...}
SPREADSHEET_NAMED_RANGES=

# ── QuickBooks Online — OAuth2 (no read-only scope exists; we only issue read queries) ──
QBO_ENV=sandbox
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REFRESH_TOKEN=
QBO_REALM_ID=
# Comma-separated QBO Account Ids to treat as FIXED cost (excluded from variable spend).
QBO_FIXED_ACCOUNT_IDS=

# ── DEV/QA ONLY: re-auth verification hook (MAD-15 AC-4) ──
# When set to 1 (and MS_ENV is not production), mounts POST /auth/test/expire-graph, which
# invalidates the caller's session refresh token so the next Graph call exercises the 401
# re-auth path. Leave unset/0 everywhere except local QA. Hard-disabled in production.
ALLOW_TEST_HOOKS=0
