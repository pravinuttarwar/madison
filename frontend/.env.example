# Front-end → backend wiring. Copy to `.env` and fill in to pull live/sandbox data.
# With none of these set, the prototype runs fully on sample data (no backend needed).

# Origin of the read-only backend (BFF). Leave blank to stay on sample data.
VITE_API_URL=http://localhost:8787

# Comma-separated sources to read from the backend instead of sample data.
# Valid ids: outlook, microsoftToDo, microsoftTeams, quickbooks, spreadsheet
VITE_LIVE_SOURCES=outlook,quickbooks

# Badge/label for wired sources: sandbox | live
VITE_LIVE_MODE=sandbox
